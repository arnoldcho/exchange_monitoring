# ----------------------------------------------------------------
# LBANK API 인증 키
# ----------------------------------------------------------------
# lbank.js / lbank_monitor_v1.1.js 가 공통으로 읽는 값.
# 경고(위험경보) 종목처럼 공개 티커에서 빠진 종목은
# 이 키로 서명(인증) 호출을 해야 조회가 가능함.
#
# 발급: LBANK 웹 > 계정 > API 관리 (https://www.lbank.com/user/api)
LBANK_API_KEY=your_lbank_api_key_here
LBANK_SECRET_KEY=your_lbank_secret_key_here

# ----------------------------------------------------------------
# 텔레그램 봇 - Smartpig Signal (급등락 알림)
# ----------------------------------------------------------------
# lbank_monitor_v1.1.js / mexc_monitor_v1.1.js 가 공통으로 사용.
# 봇 토큰: @BotFather 에서 발급 / 채널 chat_id 는 음수 형태 (예: -1001903180729)
SMARTPIG_SIGNAL_BOT_TOKEN=your_smartpig_signal_bot_token_here
SMARTPIG_SIGNAL_CHAT_ID=your_smartpig_signal_chat_id_here

# ----------------------------------------------------------------
# 텔레그램 봇 - LBANK Error Detect (API 오류 알림)
# ----------------------------------------------------------------
# lbank.js 에서 사용.
LBANK_ERROR_BOT_TOKEN=your_lbank_error_bot_token_here
LBANK_ERROR_CHAT_ID=your_lbank_error_chat_id_here

# ----------------------------------------------------------------
# 감시 대상 코인 목록 (콤마 구분, 공백 무시)
# ----------------------------------------------------------------
# 미설정 시 각 스크립트의 기본 목록(DEFAULT_TARGET_COINS) 사용.
# LBANK 은 소문자+언더바(ctp_usdt), MEXC 는 대문자(CTPUSDT) 형식.
LBANK_TARGET_COINS=ctp_usdt,ucx_usdt,cstars_usdt,pepu_usdt,mind_usdt,flock_usdt,ooju_usdt
MEXC_TARGET_COINS=BTCUSDT,ETHUSDT,XRPUSDT,CTPUSDT,PLBUSDT,PEPUUSDT,YUUSDT,BITBOARDUSDT
